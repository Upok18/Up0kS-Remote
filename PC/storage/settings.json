{
    "version": "0.3.2",
    "server": {
        "host": "0.0.0.0",
        "port": 5000,
        "max_connections": 5,
        "lan_discovery": true
    },
    "security": {
        "password_hash": "",
        "remember_devices": true,
        "trusted_devices": [
            "MAX 10"
        ],
        "lockout_minutes": 15
    },
    "ui": {
        "theme": "dark",
        "show_timestamps": true,
        "enable_keybinds": true,
        "animations": true
    },
    "startup": {
        "start_with_windows": false,
        "minimize_to_tray": false
    }
}